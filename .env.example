# ── Cosmos DB (required — the only Azure service retained) ──
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE_NAME=closedloop-os
COSMOS_CONTAINER_NAME=events

# ── Azure OpenAI (required for AI classification + embeddings) ──
AZURE_OPENAI_ENDPOINT=https://your-azure-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Notion Sync Interval (minutes) ──
NOTION_SYNC_INTERVAL_MINUTES=5

# ── Connector secrets (configure as needed) ──
GITHUB_WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
LINEAR_WEBHOOK_SECRET=
JIRA_ACCESS_TOKEN=
JIRA_WEBHOOK_SECRET=
CONFLUENCE_ACCESS_TOKEN=
CONFLUENCE_WEBHOOK_SECRET=
NOTION_ACCESS_TOKEN=
NOTION_DATABASE_ID=
NOTION_API_VERSION=2022-06-28
ZENDESK_WEBHOOK_SECRET=